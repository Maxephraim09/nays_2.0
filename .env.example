# ========================================
# PROJECT NAYS 2.0 - ENVIRONMENT EXAMPLE
# Copy this file to .env and update values
# ========================================

# Application Configuration
APP_NAME="NAYS 2.0"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=base64:YOUR_BASE64_ENCODED_KEY_HERE

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nays_db
DB_USERNAME=root
DB_PASSWORD=

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@localhost.com
MAIL_FROM_NAME="NAYS Portal"

# Payment Gateway (Test Keys)
PAYSTACK_PUBLIC_KEY=pk_test_your_test_public_key
PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key

# Security (Development Only - Generate new for production)
JWT_SECRET=your-32-character-jwt-secret
BCRYPT_ROUNDS=10

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx